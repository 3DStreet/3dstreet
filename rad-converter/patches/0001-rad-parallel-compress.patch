+        // same input bytes, same GZ_LEVEL — so the offsets/blob below are
+        // unchanged; only the wall time differs.
+        props.par_iter_mut().for_each(|(_prop, data)| {
+            *data = compress_to_vec(data, GZ_LEVEL);
+        });
+
         let mut offset = 0u64;
         for (prop, data) in props.iter_mut() {
