+
+    impl RecurseOps {
+        fn merge(&mut self, mut other: RecurseOps) {
+            self.mark_to_output.append(&mut other.mark_to_output);
+            self.set_children.append(&mut other.set_children);
+            self.clear_children.append(&mut other.clear_children);
+        }
+    }
+
+    fn recurse_to_output_par<TA: TsplatArray + Sync>(
+        splats: &TA,
