-                max_child_feature_size = max_child_feature_size.max(child_feature_size);
-                new_children.extend(child_children);
-            }
+        // Order-preserving parallel recursion: the Vec collect from par_iter
+        // matches the original sequential child order, so new_children below
+        // is byte-identical to the sequential walk's output.
+        let child_results: Vec<_> = children
+            .as_slice()
+            .par_iter()
+            .map(|&child| recurse_to_output_par(splats, child, initially_true, lod_base))
+            .collect();
+
+        let mut new_children: SmallVec<[usize; 8]> = SmallVec::new();
+        let mut max_child_feature_size = -f32::INFINITY;
+        let mut ops = RecurseOps::default();
+        for (cfs, cc, child_ops) in child_results {
+            max_child_feature_size = max_child_feature_size.max(cfs);
+            new_children.extend(cc);
+            ops.merge(child_ops);
+        }
 
-            if feature_size >= (max_child_feature_size * lod_base) {
-                to_output[index] = true;
-            }
+        let became_output = feature_size >= (max_child_feature_size * lod_base);
+        let initially = initially_true(index);
+        if became_output && !initially {
