+            ops.mark_to_output.push(index);
+        }
+        let final_to_output = initially || became_output;
 
-            if to_output[index] {
-                assert!(new_children.len() <= 65535);
-                splats.set_children(index, &new_children);
-                (feature_size, smallvec![index])
-            } else {
-                splats.set_children(index, &[]);
-                (max_child_feature_size, new_children)
-            }
+        if final_to_output {
+            assert!(new_children.len() <= 65535);
+            ops.set_children.push((index, new_children));
+            (feature_size, smallvec![index], ops)
+        } else {
+            ops.clear_children.push(index);
+            (max_child_feature_size, new_children, ops)
         }
     }
 
-    let (_root_feature_size, _root_children) = recurse_to_output(splats, root_index, &mut to_output, lod_base);
+    // Captures: both immutable usize, so the closure is auto-Send+Sync.
+    let initially_true = |i: usize| i < initial_len || i == root_index;
+    let (_root_feature_size, _root_children, ops) =
+        recurse_to_output_par(&*splats, root_index, &initially_true, lod_base);
+
+    // Apply the parallel walk's mutations sequentially. Each splat index
+    // appears at most once across these vectors, so iteration order is
+    // immaterial.
+    for i in ops.mark_to_output {
+        to_output[i] = true;
+    }
+    for (parent, children) in ops.set_children {
+        splats.set_children(parent, &children);
+    }
+    for parent in ops.clear_children {
+        splats.set_children(parent, &[]);
+    }
 
     let output_count = to_output.iter().filter(|&&b| b).count();
     logger(&format!("Output set: {} / {}", output_count, splats.len()));
