-pub fn compute_lod_tree<TA: TsplatArray>(splats: &mut TA, lod_base: f32, logger: impl Fn(&str)) {
+// Parallelism thresholds. Tuned conservatively: small inputs run sequentially
+// to avoid rayon's task-setup overhead dominating; large inputs (the cases
+// users actually wait on) get the parallel path.
+const PAR_GRID_THRESHOLD: usize = 4096;
+
+pub fn compute_lod_tree<TA: TsplatArray + Sync>(splats: &mut TA, lod_base: f32, logger: impl Fn(&str)) {
     let initial_len = splats.len();
     logger(&format!("bhatt_lod::compute_lod_tree: initial_len={}", initial_len));
 
@@ -54,13 +60,49 @@ pub fn compute_lod_tree<TA: TsplatArray>(splats: &mut TA, lod_base: f32, logger:
         }
         logger(&format!("Level: {}, step: {}, frontier: {} / {}, # active: {}, # splats: {}", level, step, frontier, initial_len, active.len(), splats.len()));
 
-        cells.clear();
         let mut grid_min_max = [I64Vec3::splat(i64::MAX), I64Vec3::splat(i64::MIN)];
 
-        for &(OrderedFloat(_neg_size), index) in active.iter() {
-            let splat = splats.get(index);
-            let grid = splat.grid(step);
-            cells.entry(grid).or_default().push(index);
+        // Embarrassingly parallel: each splat independently maps to a grid
+        // cell. Build per-thread hashmaps then merge — the merge is the only
+        // O(active.len()) sequential cost, and it's purely hashmap inserts.
+        // Below the threshold the parallel overhead loses, so we keep the
+        // simple sequential path.
+        if active.len() >= PAR_GRID_THRESHOLD {
+            // BinaryHeap doesn't expose a slice, so snapshot once into a Vec.
+            // Cheap relative to the float-heavy work inside the parallel loop.
+            let snapshot: Vec<(OrderedFloat<f32>, usize)> = active.iter().copied().collect();
+            let splats_ref: &TA = &*splats;
+            cells = snapshot
+                .par_iter()
+                .fold(
+                    || AHashMap::<I64Vec3, SmallVec<[usize; 8]>>::with_capacity(256),
+                    |mut local, &(_, index)| {
+                        let grid = splats_ref.get(index).grid(step);
+                        local.entry(grid).or_default().push(index);
+                        local
+                    },
+                )
+                .reduce(
+                    AHashMap::<I64Vec3, SmallVec<[usize; 8]>>::new,
+                    |mut a, mut b| {
+                        // Merge the smaller hashmap into the larger one to
+                        // minimize entry lookups.
+                        if a.len() < b.len() {
+                            std::mem::swap(&mut a, &mut b);
+                        }
+                        for (k, v) in b {
+                            a.entry(k).or_default().extend(v);
+                        }
+                        a
+                    },
+                );
+        } else {
+            cells.clear();
+            for &(OrderedFloat(_neg_size), index) in active.iter() {
+                let splat = splats.get(index);
+                let grid = splat.grid(step);
+                cells.entry(grid).or_default().push(index);
+            }
         }
 
         let mut next_active = Vec::new();
@@ -148,11 +190,30 @@ pub fn compute_lod_tree<TA: TsplatArray>(splats: &mut TA, lod_base: f32, logger:
     to_output.resize(splats.len(), false);
     to_output[root_index] = true;
 
-    fn recurse_to_output<TA: TsplatArray>(
-        splats: &mut TA, index: usize, to_output: &mut Vec<bool>, lod_base: f32,
