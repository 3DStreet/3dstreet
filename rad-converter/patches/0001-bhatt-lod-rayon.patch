+    ) -> (f32, SmallVec<[usize; 8]>, RecurseOps) {
         let feature_size = {
             let splat = splats.get(index);
             splat.area() * splat.opacity()
@@ -160,33 +221,62 @@ pub fn compute_lod_tree<TA: TsplatArray>(splats: &mut TA, lod_base: f32, logger:
 
         let children = splats.get_children(index);
