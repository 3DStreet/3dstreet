rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Helper functions
    function isImageUnderSizeLimit() {
      return resource.size < 100 * 1024 && resource.contentType.matches('image/.*');
    }

    function isAuthorOfScene(scene_uuid) {
      return firestore.get(/databases/(default)/documents/scenes/$(scene_uuid)).data.author == request.auth.uid;
    }

    // Scene files
    match /scenes/{scene_uuid}/files/{allPaths=**} {
      allow read: if isImageUnderSizeLimit() || request.auth != null;
      allow write: if request.auth != null && isAuthorOfScene(scene_uuid);
    }

    // Gallery asset files storage rules (all nested paths)
    // Handles: images/, videos/, meshes/, splats/{taskId}/, etc.
    match /users/{userId}/assets/{allPaths=**} {
      // Users can read their own asset files
      allow read: if request.auth != null && request.auth.uid == userId;

      // Delete: owner-only, no contentType check (request.resource is null on delete).
      allow delete: if request.auth != null && request.auth.uid == userId;

      // Create/update: owner-only with per-type size caps (decimal MB, base 1000):
      //   image/* : 10 MB
      //   model/* | application/octet-stream (GLB, PLY) : 50 MB
      //   video/* : 50 MB
      // application/octet-stream is needed for PLY files (splats); GLB blobs
      // typically arrive as model/gltf-binary but some clients send octet-stream.
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && (
          (request.resource.contentType.matches('image/.*') && request.resource.size < 10 * 1000 * 1000)
          || (request.resource.contentType.matches('model/.*') && request.resource.size < 50 * 1000 * 1000)
          || (request.resource.contentType.matches('application/octet-stream') && request.resource.size < 50 * 1000 * 1000)
          || (request.resource.contentType.matches('video/.*') && request.resource.size < 50 * 1000 * 1000)
        );
    }
  }
}
