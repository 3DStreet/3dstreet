rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Helper functions
    function isImageUnderSizeLimit() {
      return resource.size < 100 * 1024 && resource.contentType.matches('image/.*');
    }

    function isAuthorOfScene(scene_uuid) {
      return firestore.get(/databases/(default)/documents/scenes/$(scene_uuid)).data.author == request.auth.uid;
    }

    // Scene files
    match /scenes/{scene_uuid}/files/{allPaths=**} {
      allow read: if isImageUnderSizeLimit() || request.auth != null;
      allow write: if request.auth != null && isAuthorOfScene(scene_uuid);
    }

    // Gallery asset files storage rules (all nested paths)
    // Handles: images/, videos/, meshes/, splats/{taskId}/, etc.
    match /users/{userId}/assets/{allPaths=**} {
      // Users can read their own asset files
      allow read: if request.auth != null && request.auth.uid == userId;

      // Delete: disallowed for clients. Soft delete flips `deleted: true` on
      // the Firestore doc; actual byte purge is done by a garbage-collector
      // Cloud Function via Admin SDK (which bypasses these rules).

      // Create/update: owner-only, allowed content types, and a SINGLE flat
      // per-file hard ceiling (5 GB = the top plan's per-file cap). The per-file
      // limit is plan-scaled (FREE 100 MB / PRO 1 GB / MAX 5 GB) but that is
      // SOFT-enforced in getUploadQuota + the client (MAX_FILE_BYTES_BY_PLAN);
      // these rules only need the generous MAX backstop so the soft per-plan cap
      // is always the binding limit. Type-agnostic on size by design: a big
      // upload costs the same to host regardless of type. (Total storage quota
      // is a separate, additive limit handled by onAssetWritten.)
      // image/model/octet-stream(.ply)/video are the accepted gallery types;
      // GLB blobs usually arrive as model/gltf-binary but some clients send
      // octet-stream.
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1000 * 1000 * 1000
        && (
          request.resource.contentType.matches('image/.*')
          || request.resource.contentType.matches('model/.*')
          || request.resource.contentType.matches('application/octet-stream')
          || request.resource.contentType.matches('video/.*')
        );
    }
  }
}
