# Environment variables for the dev-3dstreet Firebase project.
# Firebase auto-loads .env.<project-id> from the functions source dir at deploy.
#
# Enable App Check enforcement on dev so the gate can be validated end-to-end
# before enabling it in production. With this set, callables wired with
# assertAppCheck() reject requests lacking a valid App Check token (forks,
# curl). The official clients on dev-3dstreet.web.app / localhost send tokens
# and are unaffected. For prod, mirror this in .env.dstreet-305604 only after
# the verified/unverified ratio has been monitored (see issue #1708).
APP_CHECK_ENFORCE=true
