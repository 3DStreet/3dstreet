# Environment variables for the dev-3dstreet Firebase project.
# Firebase auto-loads .env.<project-id> from the functions source dir at deploy.
#
# App Check enforcement is OFF on dev by design. Enforcing it here would require
# every contributor to have a registered App Check debug token just to run cloud
# features locally (npm start points at dev-3dstreet), and Sentry wouldn't even
# surface the resulting failed-precondition rejections. Dev is disposable and
# resource abuse is covered by budget alerts, so the gate stays wired but unset.
# Flip to true here only for a deliberate end-to-end validation pass, and in
# prod (.env.dstreet-305604) only after monitoring the verified/unverified ratio
# (see issue #1708).
APP_CHECK_ENFORCE=false
