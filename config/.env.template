# --- Optional ---------------------------------------------------------------
# Firebase App Check (recommended for any public deployment). When set, the
# client attests to Firebase with a reCAPTCHA Enterprise token so backends that
# enforce App Check accept it. Leave blank to disable App Check entirely.
FIREBASE_APP_CHECK_SITE_KEY  =
# Dev only: register an App Check debug token. Use `true` to have the SDK print
# a token to the console (register it under App Check in the Firebase console),
# or paste a previously registered debug token. Never set in production.
FIREBASE_APP_CHECK_DEBUG_TOKEN =
# Comma-separated extra hostnames considered "official" for THIS deployment.
# Self-hosters set their own domain(s) here to suppress the unofficial-build
# banner once they've pointed the app at their own Firebase project.
OFFICIAL_DEPLOYMENT_HOSTNAMES =
